{
  "name": "pixide-react",
  "description": "Pixel-style icon library for React — 1694 icons, fill-based, tree-shakeable.",
  "version": "0.1.0",
  "license": "ISC",
  "homepage": "https://github.com/haksolot/pixide-icons",
  "repository": {
    "type": "git",
    "url": "https://github.com/haksolot/pixide-icons.git",
    "directory": "packages/pixide-react"
  },
  "keywords": [
    "pixide",
    "react",
    "icons",
    "svg",
    "pixel",
    "pixel-art",
    "lucide"
  ],
  "sideEffects": false,
  "main": "dist/cjs/pixide-react.js",
  "module": "dist/esm/pixide-react.js",
  "typings": "dist/pixide-react.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/pixide-react.js",
      "require": "./dist/cjs/pixide-react.js",
      "types": "./dist/pixide-react.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "npm run clean && npm run copy:license && npm run build:bundles",
    "copy:license": "node -e \"require('fs').copyFileSync('../../LICENSE', './LICENSE')\"",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true})\"",
    "build:bundles": "rollup -c ./rollup.config.mjs",
    "typecheck": "tsc",
    "typecheck:watch": "tsc -w"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/react": "^18.2.37",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.2.3",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "^16.5.1 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  }
}
